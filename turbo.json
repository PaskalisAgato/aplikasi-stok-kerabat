{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "static/**", "index.html", "vite.config.ts", "package.json", "tsconfig.json", "../../apps/shared/**"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "../../apps/shared/**"],
      "outputs": [".tsbuildinfo"]
    }
  }
}
